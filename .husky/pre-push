#!/bin/bash

# Git Pre-Push Hook v2.0
# 在推送到远程仓库前执行全维度智能检测
# 支持自动修复和重试机制

# 设置脚本路径
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# 切换到项目根目录
cd "$PROJECT_ROOT"

# 执行完整的 pre-push 检测脚本
if [ -f "scripts/pre-push-full.sh" ]; then
    chmod +x scripts/pre-push-full.sh
    ./scripts/pre-push-full.sh
    exit_code=$?
    
    if [ $exit_code -eq 0 ]; then
        echo ""
        echo "✅ 全维度检测通过，可以安全推送！"
        exit 0
    else
        echo ""
        echo "❌ 检测失败，推送已中止"
        echo ""
        echo "💡 提示:"
        echo "   - 运行 'pnpm check:full' 查看详细错误"
        echo "   - 运行 'pnpm check:fix' 自动修复问题"
        echo "   - 修复后重新执行 'git push'"
        echo ""
        exit 1
    fi
else
    echo "⚠️  智能检测脚本不存在，跳过检查"
    echo "   请确保 scripts/pre-push-full.sh 文件存在"
    exit 0
fi
