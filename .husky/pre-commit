#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# YYC3-UI Pre-commit Hook
# 在 git commit 前自动执行智能检查

echo ""
echo "🚀 启动提交前检查..."

# 运行提交前智能检查
./scripts/pre-commit-check.sh

# 检查退出码
if [ $? -eq 0 ]; then
    echo ""
    echo "✅ 提交前检查通过，继续提交..."
    exit 0
else
    echo ""
    echo "❌ 提交前检查失败，提交已取消"
    echo "💡 请查看上方错误信息并修复问题"
    exit 1
fi
