{
  "name": "yyc3-ui",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "YYC-Cube",
    "url": "https://github.com/YYC-Cube"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "registry:build": "pnpm --filter=v4 registry:build && pnpm lint:fix && pnpm format:write -- --loglevel silent",
    "registry:capture": "pnpm --filter=v4 registry:capture",
    "explore:capture": "pnpm --filter=v4 explore:capture",
    "dev": "turbo run dev --parallel",
    "shadcn:dev": "turbo --filter=yyc3-ui dev",
    "shadcn": "pnpm --filter=yyc3-ui start:dev",
    "shadcn:prod": "pnpm --filter=yyc3-ui start:prod",
    "shadcn:build": "pnpm --filter=yyc3-ui build",
    "shadcn:test": "pnpm --filter=yyc3-ui test",
    "v4:dev": "pnpm --filter=v4 dev",
    "v4:build": "pnpm --filter=v4 build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "preview": "turbo run preview",
    "typecheck": "turbo run typecheck",
    "format:write": "turbo run format:write",
    "format:check": "turbo run format:check",
    "sync:templates": "./scripts/sync-templates.sh \"templates/*\"",
    "check": "turbo lint typecheck format:check",
    "check:quick": "./scripts/quick-check.sh",
    "check:commit": "./scripts/pre-commit-check.sh",
    "check:full": "./scripts/smart-check.sh",
    "check:verify": "./scripts/quick-verify.sh",
    "check:ci": "./scripts/ci-check.sh",
    "check:fix": "./scripts/auto-fix.sh",
    "check:push": "./scripts/pre-push-full.sh",
    "release": "changeset version",
    "pub:beta": "cd packages/yyc3-ui && pnpm pub:beta",
    "pub:release": "cd packages/yyc3-ui && pnpm pub:release",
    "test:dev": "turbo run test --filter=!yyc3-ui --force",
    "test": "start-server-and-test v4:dev http://localhost:4000 test:dev",
    "validate:registries": "pnpm --filter=v4 validate:registries",
    "test:apps": "pnpm --filter=v4 test:apps",
    "prepare": "husky"
  },
  "packageManager": "pnpm@9.0.6",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^17.8.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@manypkg/cli": "^0.20.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "autoprefixer": "^10.4.27",
    "chokidar": "^4.0.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "eslint-config-prettier": "^8.10.2",
    "eslint-config-turbo": "^1.13.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-tailwindcss": "3.13.1",
    "motion": "^12.38.0",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "puppeteer": "^23.11.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "turbo": "^1.13.4",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^4.1.2"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/node": "^20.19.37",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "husky": "^9.1.7",
    "start-server-and-test": "^2.1.5",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2"
    }
  }
}
