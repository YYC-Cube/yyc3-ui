#!/bin/bash

# Pre-commit hook
# 快速检查代码质量

echo "执行快速检查..."

# 1. 检查是否有语法错误
if git diff --cached --name-only | grep -E '\.(ts|tsx)$' | xargs -r grep -l "console\.log" > /dev/null 2>&1; then
    echo "⚠️  发现 console.log，请确认是否需要提交"
fi

# 2. 检查是否有 TODO
if git diff --cached --name-only | xargs -r grep -i "TODO" > /dev/null 2>&1; then
    echo "ℹ️  发现 TODO 标记"
fi

echo "✓ Pre-commit 检查通过"
